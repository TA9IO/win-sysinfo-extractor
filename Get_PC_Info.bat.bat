@echo off
set "outputFile=PC_Info_%COMPUTERNAME%.txt"
echo Gathering comprehensive system info...

powershell -NoProfile -ExecutionPolicy Bypass -Command "$out = @(); $out += '========================================'; $out += '          SYSTEM INFORMATION            '; $out += '========================================'; $out += 'Computer Name : ' + $env:COMPUTERNAME; $out += 'Logged-in User: ' + $env:USERNAME; $out += 'Model         : ' + (Get-CimInstance Win32_ComputerSystem).Model; $out += 'Serial Number : ' + (Get-CimInstance Win32_BIOS).SerialNumber; $out += 'BIOS Version  : ' + (Get-CimInstance Win32_BIOS).SMBIOSBIOSVersion; $out += 'CPU           : ' + (Get-CimInstance Win32_Processor).Name; $out += 'RAM           : ' + [math]::Round((Get-CimInstance Win32_ComputerSystem).TotalPhysicalMemory / 1GB, 2) + ' GB'; foreach ($gpu in Get-CimInstance Win32_VideoController) { $out += 'GPU           : ' + $gpu.Name }; $out += 'OS            : ' + (Get-CimInstance Win32_OperatingSystem).Caption; $out += 'System Uptime : ' + ((Get-Date) - (Get-CimInstance Win32_OperatingSystem).LastBootUpTime).ToString('dd\.hh\:mm\:ss'); $out += 'IP Address    : ' + (Get-NetIPAddress -AddressFamily IPv4 | Where-Object {$_.InterfaceAlias -notlike '*Loopback*' -and $_.PrefixLength -lt 32}).IPAddress; $out += '----------------------------------------'; $out += '              DISK DRIVES               '; $out += '----------------------------------------'; foreach ($d in Get-PhysicalDisk) { $out += 'Disk          : ' + $d.FriendlyName; $out += 'Type          : ' + $d.MediaType; $out += 'Size          : ' + [math]::Round($d.Size / 1GB, 2) + ' GB'; $out += '---' }; $out | Out-File -FilePath '%outputFile%' -Encoding utf8"

echo Successfully generated %outputFile%!